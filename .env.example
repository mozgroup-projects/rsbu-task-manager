# ---- Database (Supabase Postgres) ----
# Pooled connection (used by the app at runtime). Append ?pgbouncer=true&connection_limit=1
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (used by Prisma migrations)
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# ---- NextAuth / Auth.js ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="changeme"
# In production set to your deployed URL, e.g. https://rsbu-task.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ---- Google OAuth (login + Calendar) ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Supabase Storage (file attachments) ----
NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only key for signed uploads/downloads — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=""
# Storage bucket name for attachments
SUPABASE_STORAGE_BUCKET="attachments"

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=""
# Public username of the bot (without @), used to build the deep-link in settings
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""

# ---- Cron protection ----
# Generate with: openssl rand -hex 24. Vercel Cron sends this as Authorization: Bearer <secret>
CRON_SECRET="changeme"
